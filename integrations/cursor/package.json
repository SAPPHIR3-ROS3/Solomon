{
  "name": "solomon-cursor-integration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "test": "esbuild test/openai-tools.test.ts --bundle --platform=node --format=esm --outfile=.test/openai-tools.test.mjs --packages=external && node --test .test/openai-tools.test.mjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.13"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "sqlite3": "6.0.1",
    "tar": "7.5.15",
    "undici": "6.24.0",
    "@tootallnate/once": "2.0.1",
    "node-gyp": "12.2.0",
    "http-proxy-agent": "7.0.6",
    "make-fetch-happen": "14.0.3",
    "cacache": "19.0.1"
  }
}
